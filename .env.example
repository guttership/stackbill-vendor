# ============================================================================
# StackBill Vendor - Environment Variables
# ============================================================================

# ⚠️ SECURITY: Never commit this file with real values!
# Copy to .env.local and fill with your actual credentials

# Stripe API Keys
# Get from: https://dashboard.stripe.com/apikeys
# ⚠️ Use TEST keys (sk_test_/pk_test_) for development
# ⚠️ Use LIVE keys (sk_live_/pk_live_) for production ONLY
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs
# Create products in Stripe Dashboard and copy price IDs
NEXT_PUBLIC_STRIPE_MONTHLY_PRICE_ID=
NEXT_PUBLIC_STRIPE_YEARLY_PRICE_ID=

# Application URL
# Development: http://localhost:3000
# Production: https://vendor.yourdomain.com (MUST use HTTPS)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Private storage download signing
# Base URL must point to your private storage delivery endpoint (S3/R2/CDN origin)
# Example: https://downloads.stackbill.tech/private
PRIVATE_DOWNLOAD_BASE_URL=
PRIVATE_DOWNLOAD_SIGNING_SECRET=
# Optional: defaults to 90 seconds
PRIVATE_DOWNLOAD_URL_TTL_SECONDS=90

# Database (PostgreSQL)
# ⚠️ Use sslmode=require in production
DATABASE_URL=postgresql://user:password@host:5432/vendor?sslmode=require
